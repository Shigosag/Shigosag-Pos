generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id        String   @id @default(cuid())
  name      String
  price     Float
  stock     Int
  barcode   String?  @unique
  createdAt DateTime @default(now())
}

model Sale {
  id        String   @id @default(cuid())
  total     Float
  items     String
  createdAt DateTime @default(now())
}